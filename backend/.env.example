# ── Server Configuration ──────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database Configuration (MySQL / TiDB Cloud) ───────────────────
# For TiDB Cloud, use port 4000 and set DB_SSL=true
DB_HOST=your-tidb-cloud-host.gateway.prod.aws.tidbcloud.com
DB_USER=your_cluster_id.root
DB_PASSWORD=your_tidb_cloud_password
DB_NAME=mcms
DB_PORT=4000
DB_SSL=true

# ── JWT Secret ────────────────────────────────────────────────────
JWT_SECRET=your_very_secure_jwt_secret_change_this
JWT_EXPIRE=30d

# ── Frontend URL (for CORS in development) ────────────────────────
FRONTEND_URL=https://your-frontend.onrender.com

# ── Groq API Key (for AI Assistant) ───────────────────────────────
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── First Deploy Only ─────────────────────────────────────────────
# Set to 'true' on the very first deploy to auto-create admin users
# Remove after first successful login
# DB_SYNC=true
